{
  "schema_version": 10,
  "log_level": "INFO",
  "theme": "dark",
  "pipeline": {
    "db_writer_batch_size": 5000,
    "db_writer_flush_interval_ms": 500,
    "job_claim_batch_size": 10,
    "scanner_worker_threads": 1,
    "hash_worker_processes": null,
    "metadata_worker_threads": 3,
    "retry_base_delay_seconds": 5.0,
    "retry_max_delay_seconds": 300.0
  },
  "metadata": {
    "confidence_threshold": 0.90,
    "provider_order": ["acoustid", "musicbrainz", "local_tags", "filename_parser"],
    "enabled_providers": ["acoustid", "musicbrainz", "local_tags", "filename_parser"],
    "acoustid_api_key": "",
    "fingerprint_mode": "all",
    "fingerprint_sample_min": 3
  },
  "watch": {
    "poll_interval_seconds": 30.0
  },
  "artwork": {
    "fetch_enabled": true,
    "min_width": 500,
    "min_height": 500
  },
  "acquisition": {
    "enabled_providers": ["stub"],
    "provider_order": ["nicotine_plus", "stub"],
    "search_timeout_seconds": 30.0,
    "auto_queue_jobs": true,
    "auto_acquire_threshold": 0.90,
    "nicotine_plus": {
      "enabled": false,
      "host": "127.0.0.1",
      "port": 22024,
      "transport": "socket",
      "api_port": 12339,
      "api_token": "",
      "username": "",
      "password": ""
    }
  }
}
